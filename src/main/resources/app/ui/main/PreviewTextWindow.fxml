<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox prefHeight="455.0" prefWidth="616.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox prefHeight="391.0" prefWidth="606.0">
         <children>
            <WebView fx:id="webView" prefHeight="411.0" prefWidth="616.0" />
         </children>
         <VBox.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </VBox.margin>
      </VBox>
      <HBox alignment="CENTER" prefHeight="42.0" prefWidth="616.0" spacing="20.0">
         <children>
            <Button fx:id="bttText" mnemonicParsing="false" prefHeight="25.0" prefWidth="120.0" text="Texto">
               <graphic>
                  <ImageView fitHeight="17.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@text-box.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
            <Button fx:id="bttCod" mnemonicParsing="false" prefHeight="10.0" prefWidth="120.0" text="Código">
               <graphic>
                  <ImageView fitHeight="17.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@code.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>
